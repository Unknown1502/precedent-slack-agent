# ─── Slack ───────────────────────────────────────────────────────────────
# Bot token (xoxb-…) and App-level token (xapp-…, connections:write) for Socket Mode.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=

# ─── LLM provider (groq | anthropic | gemini) ────────────────────────────
# Default = Groq free tier. model_* are provider-specific IDs.
LLM_PROVIDER=groq
GROQ_API_KEY=              # console.groq.com -> API Keys (gsk-…)
ANTHROPIC_API_KEY=        # only if LLM_PROVIDER=anthropic (verify IDs at docs.claude.com)
GEMINI_API_KEY=           # only if LLM_PROVIDER=gemini (aistudio.google.com)
MODEL_GATE=llama-3.1-8b-instant       # fast classifier (Gatekeeper)
MODEL_REASON=llama-3.3-70b-versatile  # reasoning (Extractor/Sentinel/Archivist)

# ─── Embeddings (pick ONE provider; set EMBED_DIM to match) ───────────────
# voyage-3 => 1024 dim   |   openai text-embedding-3-small => 1536 dim
VOYAGE_API_KEY=
EMBED_MODEL=voyage-3
EMBED_DIM=1024

# ─── Database (Neon Postgres + pgvector) ──────────────────────────────────
# Local dev via Docker:  postgresql://precedent:precedent@localhost:5433/precedent
DATABASE_URL=

# ─── MCP ─────────────────────────────────────────────────────────────────
MCP_BEARER_TOKEN=

# ─── Runtime ─────────────────────────────────────────────────────────────
PORT=3000
MODE=socket
DRIFT_THRESHOLD=0.78
SEED_MODE=0
TEAM_ID=lumina-labs
